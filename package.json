{
  "name": "dynastyglobaltech",
  "version": "1.0.0",
  "description": "DynastyGlobalTech - Full Stack MERN Application",
  "main": "backend/server/index.js",
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend/client",
    "start": "concurrently \"npm run server\" \"npm run client\"",
    "server": "npm run server --prefix backend",
    "client": "npm run dev --prefix frontend/client",
    "build": "npm run build --prefix frontend/client",
    "dev": "npm start"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
